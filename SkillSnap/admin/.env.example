# Admin Vite app — copy to `.env` for local dev.
#
# Must point at the HTTP API base including the /api prefix (trailing slashes are stripped in code).
# If you use only host:port (e.g. http://localhost:8080), /api is appended automatically.

# Production (Render):
# VITE_API_BASE_URL=https://skillsnap-ushm.onrender.com/api
VITE_API_BASE_URL=http://localhost:8080/api

# Production deploy (Vercel): set VITE_API_BASE_URL to your Render API (…/api). Public app URL:
# https://skillsnap-admin-one.vercel.app

# If port 5173 is already in use, set another port (must match the URL you open in the browser).
# ADMIN_DEV_PORT=5178
